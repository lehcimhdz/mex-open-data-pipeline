# Copy this file to .env and fill in all values before running docker compose.
# NEVER commit .env to git — it is listed in .gitignore.

AIRFLOW_UID=50000

# Airflow security — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=change-me-to-a-random-32-char-hex-string
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change-me-to-a-strong-password

# AWS region — must match your Terraform deployment
AWS_DEFAULT_REGION=mx-central-1

# If running on EC2 with the pipeline IAM role attached, leave these commented out.
# If running locally, provide credentials with S3 + Glue access.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Airflow Variables — set via CLI after the stack is running:
#
#   docker compose exec airflow-scheduler \
#     airflow variables set DATA_LAKE_BUCKET mex-open-data-lake-123456789012
#
#   docker compose exec airflow-scheduler \
#     airflow variables set GLUE_CRAWLER_NAME mex-open-data-curated-crawler
#
# The bucket name and crawler name are printed by `terraform output` after apply.
# ---------------------------------------------------------------------------
