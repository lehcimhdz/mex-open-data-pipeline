# Copy this file to .env and fill in the values before running docker compose.

AIRFLOW_UID=50000

# AWS region — must match your Terraform deployment
AWS_DEFAULT_REGION=mx-central-1

# If running on EC2 with the pipeline IAM role attached, leave these commented out.
# If running locally, set your credentials here.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Airflow Variables — set via the UI or CLI after the stack is running:
#
#   docker compose exec airflow-scheduler \
#     airflow variables set DATA_LAKE_BUCKET mex-open-data-lake-123456789012
#
#   docker compose exec airflow-scheduler \
#     airflow variables set GLUE_CRAWLER_NAME mex-open-data-curated-crawler
#
# The bucket name and crawler name are printed by `terraform output` after apply.
# ---------------------------------------------------------------------------
